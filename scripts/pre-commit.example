#!/bin/sh
#
# Git pre-commit hook example
# Place this file at .git/hooks/pre-commit (without .example extension)
#

# Check for unconverted images
unconverted=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(jpg|png)$' | while read f; do
    webp="${f%.*}.webp"
    if [ -f "$f" ] && [ ! -f "$webp" ]; then
        echo "  $f"
    fi
done)

if [ -n "$unconverted" ]; then
    echo "ERROR: Unconverted images detected:"
    echo "$unconverted"
    echo ""
    echo "Run: ./scripts/optimize-images.sh"
    exit 1
fi

# Optional: Run audit to verify all images are converted
if [ -x "./scripts/audit-images.sh" ]; then
    if ! ./scripts/audit-images.sh > /dev/null 2>&1; then
        echo "ERROR: Image audit failed. Run ./scripts/audit-images.sh for details"
        exit 1
    fi
fi

exit 0
